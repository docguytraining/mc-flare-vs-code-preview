{
  "name": "mc-flare-vs-code-preview",
  "displayName": "MadCap Flare Preview",
  "description": "Preview MadCap Flare HTML topics in VS Code with Flare-aware rendering of variables, snippets, conditionals, and stylesheets.",
  "version": "0.1.0",
  "publisher": "paulpehrson",
  "license": "MIT",
  "private": true,
  "engines": {
    "vscode": "^1.95.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/paulpehrson/mc-flare-vs-code-preview.git"
  },
  "bugs": {
    "url": "https://github.com/paulpehrson/mc-flare-vs-code-preview/issues"
  },
  "homepage": "https://github.com/paulpehrson/mc-flare-vs-code-preview#readme",
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "madcap",
    "flare",
    "html",
    "preview",
    "documentation",
    "technical writing",
    "help authoring"
  ],
  "activationEvents": [
    "onLanguage:html",
    "workspaceContains:**/*.flprj"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flare.previewHtml",
        "title": "Flare Preview",
        "shortTitle": "Flare Preview",
        "category": "Flare"
      },
      {
        "command": "flare.insertXref",
        "title": "Flare: Insert Cross-Reference",
        "category": "Flare"
      },
      {
        "command": "flare.dismissVariableSuggestion",
        "title": "Flare: Dismiss Variable Suggestion",
        "category": "Flare",
        "enablement": "false"
      },
      {
        "command": "flare.dismissVariableSuggestionInTopic",
        "title": "Flare: Dismiss Variable Suggestion (Topic)",
        "category": "Flare",
        "enablement": "false"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "flare.previewHtml",
          "when": "resourceExtname == .htm || resourceExtname == .html",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "flare.insertXref",
          "when": "resourceExtname == .htm || resourceExtname == .html",
          "group": "1_modification"
        }
      ],
      "explorer/context": [
        {
          "command": "flare.previewHtml",
          "when": "resourceExtname == .htm || resourceExtname == .html",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "MadCap Flare Preview",
      "properties": {
        "flarePreview.autoRefreshOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Refresh the preview after saving an HTML topic."
        },
        "flarePreview.typingDebounceMs": {
          "type": "number",
          "default": 800,
          "minimum": 300,
          "description": "Debounce delay used for typing-driven preview refresh."
        },
        "flarePreview.inlayHints.variables": {
          "type": "boolean",
          "default": true,
          "description": "Show the resolved value of each Flare variable reference as an inline hint in the editor."
        },
        "flarePreview.suggestVariableReplacements": {
          "type": "boolean",
          "default": true,
          "description": "Suggest replacing literal text that matches a Flare variable value with a <MadCap:variable> reference."
        },
        "flarePreview.variableReplacementMinLength": {
          "type": "number",
          "default": 4,
          "minimum": 2,
          "description": "Minimum length of a variable value before it is used for literal-match suggestions. Lower values produce more noise on short words."
        },
        "flarePreview.suggestionIgnoreVariables": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Project-wide list of Flare variable names that should never produce literal-match suggestions or value-prefix completions. Add either the qualified name (e.g. 'UI.user') or the bare name. For per-topic dismissals, insert an inline '<!-- flare:no-suggest VariableName -->' comment instead."
        },
        "flarePreview.validateLinks": {
          "type": "boolean",
          "default": true,
          "description": "Validate local links, images, snippet sources, stylesheets, and MadCap cross-references in Flare topics."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext .ts",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.8",
    "@types/node": "^20.17.6",
    "@types/vscode": "^1.95.0",
    "@typescript-eslint/eslint-plugin": "^8.12.2",
    "@typescript-eslint/parser": "^8.12.2",
    "@vscode/test-electron": "^2.4.1",
    "eslint": "^9.14.0",
    "glob": "^11.0.1",
    "mocha": "^10.8.2",
    "typescript": "^5.6.3",
    "@vscode/vsce": "^3.2.1"
  }
}
